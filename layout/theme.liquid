<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title }} | {{ shop.name }}</title>

    {{ content_for_header }}

    <link href="{{ 'style.css' | asset_url }}" rel="stylesheet" type="text/css" media="all">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
</head>
<body>

    <div class="top-bar">
        <div class="container top-bar-flex">
            <span>✉️ pools@velcrest.africa</span>
            <span class="user-links">
                {% if customer %}
                    Welcome, {{ customer.first_name }} | <a href="{{ routes.account_logout_url }}">Log Out</a>
                {% else %}
                    Welcome, Guest | <a href="{{ routes.account_login_url }}">Login</a>
                {% endif %}
            </span>
        </div>
    </div>

    <header class="main-header fade-in">
        <div class="container header-flex">
            
            <div class="logo">
                <a href="{{ routes.root_url }}">
                    <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" class="brand-logo">
                </a>
            </div>
            
            <form class="search-wrapper" action="{{ routes.search_url }}" method="get">
                <input type="text" name="q" placeholder="Search Velcrest Prime" value="{{ search.terms | escape }}" required>
                <button type="submit">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                </button>
            </form>

            <div class="header-actions">
                <a href="{{ routes.account_login_url }}" class="login-btn">Log In</a>
                <a href="/collections/all" class="view-catalogues">View Specials</a>
                <a href="{{ routes.cart_url }}" class="cart-wrapper" style="text-decoration: none;">
                    <svg class="cart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                    <span class="cart-text">Cart ({{ cart.item_count }})</span>
                </a>
            </div>
        </div>
    </header>

    <nav class="main-nav fade-in">
        <div class="container">
            <ul class="nav-list">
                <li class="has-dropdown"><a href="/collections/all">Pool & Outdoor ⌄</a>
                    <div class="mega-menu">
                        <div class="container mega-menu-grid">
                            <div class="menu-column"><h4>Pool Maintenance</h4><ul><li><a href="/collections/all">Automatic Pool Cleaners</a></li><li><a href="/collections/all">Zodiac Cleaners</a></li></ul></div>
                            <div class="menu-column"><h4>Chemicals</h4><ul><li><a href="/collections/all">Chlorine & Floaties</a></li><li><a href="/collections/all">Shock Treatment</a></li></ul></div>
                            <div class="menu-column"><h4>Pumps & Hardware</h4><ul><li><a href="/collections/all">Pool Pumps</a></li><li><a href="/collections/all">Sand Filters</a></li></ul></div>
                        </div>
                    </div>
                </li>
                <li class="has-dropdown"><a href="/collections/all">Appliances & Cooling ⌄</a>
                    <div class="mega-menu">
                        <div class="container mega-menu-grid">
                            <div class="menu-column"><h4>Fridges</h4><ul><li><a href="/collections/all">Double Door Fridges</a></li><li><a href="/collections/all">Chest Freezers</a></li></ul></div>
                            <div class="menu-column"><h4>Coolers</h4><ul><li><a href="/collections/all">Wine Coolers</a></li></ul></div>
                        </div>
                    </div>
                </li>
                <li><a href="/collections/all" style="color: #F8BA3D;">Sale & Specials</a></li>
            </ul>
        </div>
    </nav>

    <main role="main">
        {{ content_for_layout }}
    </main>

    <footer class="main-footer">
        <div class="container footer-content">
            <div class="footer-column">
                <img src="{{ 'logo.png' | asset_url }}" alt="Velcrest Logo" style="max-height: 40px; margin-bottom: 20px; filter: grayscale(1) brightness(2);">
                <p>Your premium destination for high-end accessories.</p>
            </div>
            <div class="footer-column"><h4>Service</h4><ul><li><a href="#">Track Order</a></li><li><a href="/pages/returns">Returns</a></li></ul></div>
            <div class="footer-column"><h4>Contact</h4><p>✉️ pools@velcrest.africa</p><p>📍 Shop 8, Corner Lanham & De La Rey St, Bronkhorstspruit</p></div>
        </div>
        <div class="footer-bottom"><p>&copy; {{ 'now' | date: "%Y" }} Velcrest Prime. All rights reserved.</p></div>
    </footer>

</body>
</html>