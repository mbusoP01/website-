<section class="hero-section fade-in">
    <div class="hero-content">
        <h2>Unlock Premium Savings</h2>
        <p>Stock up and save on our exclusive pool gear and cooling solutions.</p>
        <a href="/collections/all" class="cta-button shimmer-btn">Shop Now</a>
    </div>
</section>

<section class="container fade-in-delay-1">
    <div class="promo-banner">
        <div class="promo-texture"></div>
        <div class="promo-content">
            <h2>Big deals, bigger savings.</h2>
            <p>Bounce back to savings with our latest premium specials.</p>
            <a href="/collections/all" class="cta-button shimmer-btn">View Catalogues</a>
        </div>
        <div class="promo-images">
            <img src="https://via.placeholder.com/350x220/ffffff/1A8F8D?text=Catalogue" class="promo-img-main" alt="Catalogue">
            <img src="https://via.placeholder.com/150x150/F8BA3D/232323?text=Product+1" class="promo-img-float-1 floating-anim" alt="Float 1">
            <img src="https://via.placeholder.com/120x120/232323/ffffff?text=Product+2" class="promo-img-float-2 floating-anim-alt" alt="Float 2">
        </div>
    </div>
</section>

<section class="products-section container fade-in-delay-1">
    <h3 class="section-title">Top Sellers</h3>
    <div class="product-grid">
        
        {% for product in collections['frontpage'].products limit: 4 %}
        <a href="{{ product.url }}" class="product-card">
            <div class="product-image-container">
                <img src="{{ product.featured_image | img_url: '500x500' }}" alt="{{ product.title }}" class="product-img">
            </div>
            <div class="product-info">
                <span class="product-category">{{ product.vendor }}</span>
                <h4 class="product-title">{{ product.title }}</h4>
                <div class="product-price">{{ product.price | money }}</div>
                <button class="add-to-cart-btn shimmer-btn">View Product</button>
            </div>
        </a>
        {% else %}
        <a href="#" class="product-card">
            <div class="product-image-container"><img src="https://via.placeholder.com/300x300/ffffff/cccccc?text=Add+Products" class="product-img" alt="Placeholder"></div>
            <div class="product-info"><span class="product-category">Fridges</span><h4 class="product-title">Premium Display Cooler</h4><div class="product-price">R 8,499.00</div><button class="add-to-cart-btn shimmer-btn">View Product</button></div>
        </a>
        <a href="#" class="product-card">
            <div class="product-image-container"><img src="https://via.placeholder.com/300x300/ffffff/cccccc?text=Add+Products" class="product-img" alt="Placeholder"></div>
            <div class="product-info"><span class="product-category">Pools</span><h4 class="product-title">Automatic Pool Cleaner Pro</h4><div class="product-price">R 2,150.00</div><button class="add-to-cart-btn shimmer-btn">View Product</button></div>
        </a>
        <a href="#" class="product-card">
            <div class="product-image-container"><img src="https://via.placeholder.com/300x300/ffffff/cccccc?text=Add+Products" class="product-img" alt="Placeholder"></div>
            <div class="product-info"><span class="product-category">Cooling</span><h4 class="product-title">Matte Black Ceiling Fan</h4><div class="product-price">R 1,899.00</div><button class="add-to-cart-btn shimmer-btn">View Product</button></div>
        </a>
        <a href="#" class="product-card">
            <div class="product-image-container"><img src="https://via.placeholder.com/300x300/ffffff/cccccc?text=Add+Products" class="product-img" alt="Placeholder"></div>
            <div class="product-info"><span class="product-category">Storage</span><h4 class="product-title">Heavy Duty Caddii Box</h4><div class="product-price">R 3,200.00</div><button class="add-to-cart-btn shimmer-btn">View Product</button></div>
        </a>
        {% endfor %}

    </div>
</section>

{% schema %}
{
  "name": "Velcrest Homepage",
  "presets": [
    {
      "name": "Velcrest Homepage"
    }
  ]
}
{% endschema %}